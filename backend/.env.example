# =========================================================================
# NEXUS Specialty Hospital Platform - Template Configuration Example
# =========================================================================

# Database Connection (SQLAlchemy format. Support for SQLite, PostgreSQL, MySQL)
DATABASE_URL=sqlite:///emergency.db

# JWT Token Signing Secret (Keep this secure and unique in production)
JWT_SECRET=your_32_byte_random_hex_signing_secret_here

# Symmetric Encryption Key (Base64-encoded 32-byte key generated via cryptography.fernet.Fernet.generate_key())
ENCRYPTION_KEY=your_cryptography_fernet_aes_256_symmetric_key_here

# System Time override for clinical dashboard events (ISO-8601 format)
CURRENT_TIME=2026-07-16T13:40:00
